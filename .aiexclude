# ============================================
# Quant Agent - AI 上下文排除配置
# 减少 AI 读取的无关上下文，提升响应质量与速度
# ============================================

# ────────────────────────────────────────────
# 1. 依赖目录 (最大体积优先排除)
# ────────────────────────────────────────────
node_modules/**
frontend/node_modules/**
.venv/**
venv/**
env/**
ENV/**

# ────────────────────────────────────────────
# 2. Git 内部对象
# ────────────────────────────────────────────
.git/**

# ────────────────────────────────────────────
# 3. 编译产物与二进制缓存
# ────────────────────────────────────────────
**/__pycache__/**
**/*.py[cod]
**/*.pyo
**/*.pyd
**/*.so
**/*.dll
**/*.dylib
**/*.tsbuildinfo

# ────────────────────────────────────────────
# 4. 前端构建产物
# ────────────────────────────────────────────
frontend/dist/**
frontend/build/**
frontend/.vite/**
frontend/coverage/**

# ────────────────────────────────────────────
# 5. 日志文件 (含 259MB error.log)
# ────────────────────────────────────────────
**/logs/**
**/*.log
**/*.log.*

# ────────────────────────────────────────────
# 6. 数据库与持久化文件
# ────────────────────────────────────────────
**/*.db
**/*.db-shm
**/*.db-wal
**/*.sqlite
**/*.sqlite3
dump.rdb
quant_data_storage/**

# ────────────────────────────────────────────
# 7. Lock 文件 (纯依赖锁定，无逻辑价值)
# ────────────────────────────────────────────
uv.lock
package-lock.json
pnpm-lock.yaml
yarn.lock

# ────────────────────────────────────────────
# 8. 测试覆盖率报告与缓存
# ────────────────────────────────────────────
htmlcov/**
.coverage
.coverage.*
**/coverage/**
**/coverage.json
**/cov_annotate/**
.pytest_cache/**
**/.pytest_cache/**
.tox/**
reports/**

# ────────────────────────────────────────────
# 9. 类型检查与 Lint 缓存
# ────────────────────────────────────────────
.mypy_cache/**
**/.mypy_cache/**
.ruff_cache/**
.flake8_cache/**
.dmypy.json
dmypy.json

# ────────────────────────────────────────────
# 10. AI 工具缓存与临时状态
# ────────────────────────────────────────────
.qoder/**
.qoder-cn/**
.memory/**
.tools_cache.db
**/.tools_cache.db

# ────────────────────────────────────────────
# 11. 截图与图片 (根目录调试截图)
# ────────────────────────────────────────────
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.ico
*.bmp
*.svg

# ────────────────────────────────────────────
# 12. 大型静态文档与二进制附件
# ────────────────────────────────────────────
**/*.pdf
**/*.xlsx
**/*.pptx
**/*.zip
**/*.tar
**/*.tar.gz
**/*.rar
**/*.7z

# ────────────────────────────────────────────
# 13. 临时文件、备份与编辑器交换文件
# ────────────────────────────────────────────
**/*.bak
**/*.backup
**/*.tmp
**/*.temp
**/*.swp
**/*.swo
**/*.prof
**/*.pid
**/*.pid.lock

# ────────────────────────────────────────────
# 14. IDE 与编辑器配置
# ────────────────────────────────────────────
.vscode/**
.idea/**
*.iml
*.iws
*.ipr
.eslintcache

# ────────────────────────────────────────────
# 15. 数据目录 (行情仓库 & 沙箱数据)
# ────────────────────────────────────────────
data/**

# ────────────────────────────────────────────
# 16. Protobuf 编译产物 (保留 .proto 源文件)
# ────────────────────────────────────────────
shared/proto/*.js
