# ==========================================
# 数据节点轻量级镜像 (Data Node Slim)
# 仅包含 AKShare + YFinance 采集器
# ==========================================

# ── 阶段 1：构建依赖 ──
FROM python:3.11-slim AS builder
WORKDIR /app

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/ \
    UV_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/ \
    UV_HTTP_TIMEOUT=300

# 安装 uv
RUN pip install --no-cache-dir -i https://mirrors.aliyun.com/pypi/simple/ uv

# 数据节点专用依赖（精简版）
RUN uv pip install --system \
    akshare>=1.1.15 \
    yfinance>=0.2.36 \
    pandas>=2.0.0 \
    redis>=5.0.0 \
    httpx>=0.27.0 \
    tenacity>=8.2.0 \
    python-dotenv>=1.0.0 \
    structlog>=26.1.0 \
    rich>=13.0.0

# ── 阶段 2：运行镜像 ──
FROM python:3.11-slim
WORKDIR /app

ENV TZ=Asia/Shanghai \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

# 运行时系统库
RUN sed -i 's|http://deb.debian.org|https://mirrors.aliyun.com|g' /etc/apt/sources.list.d/debian.sources || \
    sed -i 's|http://deb.debian.org|https://mirrors.aliyun.com|g' /etc/apt/sources.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends libgomp1 && \
    rm -rf /var/lib/apt/lists/*

# 从 builder 复制精简依赖
COPY --from=builder /usr/local/lib/python3.11/site-packages /usr/local/lib/python3.11/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# 只复制数据节点需要的代码
COPY backend/core/ ./backend/core/
COPY backend/services/datasource/ ./backend/services/datasource/
COPY backend/services/akshare_service.py ./backend/services/
COPY backend/services/yfinance_service.py ./backend/services/
COPY backend/workers/ ./backend/workers/
COPY backend/worker.py ./backend/
COPY backend/__init__.py ./backend/

# 创建 reports 目录
RUN mkdir -p /app/reports

CMD ["python", "backend/worker.py"]
