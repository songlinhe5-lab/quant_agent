{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "🗺️ 节点存活总览",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "count(quant_dist_node_status == 2) or vector(0)",
          "legendFormat": "Active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "title": "节点状态 (按节点)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "quant_dist_node_status",
          "legendFormat": "{{node_id}} ({{region}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DEAD", "color": "red" }, "1": { "text": "DRAINING", "color": "yellow" }, "2": { "text": "ACTIVE", "color": "green" } } }
          ]
        }
      }
    },
    {
      "title": "心跳延迟 (距现在秒数)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "time() - quant_dist_node_heartbeat_timestamp",
          "legendFormat": "{{node_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 60 }
            ]
          },
          "unit": "s"
        }
      }
    },
    {
      "title": "YF 节点 429 限流速率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "rate(quant_dist_yf_429_total[5m])",
          "legendFormat": "{{node_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 50 },
          "unit": "ops"
        }
      }
    },
    {
      "title": "YF Failover 事件速率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "rate(quant_dist_yf_failover_total[5m])",
          "legendFormat": "{{from_node}} → {{to_node}} ({{reason}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 50 },
          "unit": "ops"
        }
      }
    },
    {
      "title": "STALE 缓存降级事件",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "rate(quant_dist_yf_stale_fallback_total[5m])",
          "legendFormat": "YF: {{cache_key}}"
        },
        {
          "expr": "rate(quant_dist_ak_stale_fallback_total[5m])",
          "legendFormat": "AK: {{action}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 },
          "unit": "ops"
        }
      }
    },
    {
      "title": "存活节点数 (按能力)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "quant_dist_node_alive_count",
          "legendFormat": "{{capability}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 2 }
            ]
          }
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["quant-agent", "distributed", "DIST-20"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "Quant Agent - 分布式节点监控 (DIST-20)",
  "uid": "quant-dist-nodes",
  "version": 1
}
