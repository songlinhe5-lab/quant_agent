# ==========================================
# 🏠 北京主节点 .env 配置模板
# ==========================================
# 部署路径: /opt/quant-agent/.env
# 角色: Master (API + Worker + 基础设施 + 监控)
# COMPOSE_PROFILES=master,monitoring
# ==========================================

# 节点角色
NODE_ROLE=master
COMPOSE_PROFILES=master,monitoring

# 采集器配置 (北京节点: akshare 国内直连 + yfinance 兜底)
COLLECTOR_AKSHARE=true
COLLECTOR_YFINANCE=true
COLLECTOR_FUTU=false
COLLECTOR_FINNHUB=false

# 静态从节点 (冷启动兜底，运行时通过 Redis 自动发现)
# 格式: http://host:port,http://host2:port
# 加州 slave 通过 Tailscale 内网 IP 通信
SLAVE_NODES=http://100.x.x.x:8001

# ==========================================
# Redis (主节点运行 Redis 实例)
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>

# ==========================================
# PostgreSQL (主节点运行)
# ==========================================
DB_USER=quant_admin
DB_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>
DB_NAME=quant_agent_db
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@127.0.0.1:5432/${DB_NAME}
EMBEDDING_DIM=1024

# Meilisearch
MEILISEARCH_HOST="http://127.0.0.1:7700"
MEILISEARCH_API_KEY="<CHANGE_ME>"

# ==========================================
# LLM API Keys
# ==========================================
LLM_API_KEY=<DEEPSEEKEY_API_KEY>
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_PRO_MODEL=deepseek-chat

# ==========================================
# 数据源 API Keys
# ==========================================
FMP_API_KEY=<FMP_KEY>
FINNHUB_API_KEY=<FINNHUB_KEY>
FRED_API_KEY=<FRED_KEY>

# ==========================================
# 交易 (Futu OpenD 在加州节点，北京不启用)
# ==========================================
FUTU_ENABLED=false
FUTU_TRD_ENV=SIMULATE

# ==========================================
# 安全与加密
# ==========================================
INTERNAL_API_SECRET=<CHANGE_ME_64_CHAR_SECRET>
ENCRYPTION_MASTER_KEY=<CHANGE_ME_64_CHAR_HEX_KEY>

# ==========================================
# CORS (前端域名)
# ==========================================
ALLOWED_ORIGINS=https://your-domain.pages.dev,http://localhost:5173

# ==========================================
# 监控通知
# ==========================================
FEISHU_WEBHOOK_URL=<FEISHU_WEBHOOK>
FEISHU_SECRET=<FEISHU_SECRET>

# ==========================================
# 环境
# ==========================================
QUANT_ENV=production
REAL_TRADE_EXECUTE=false
