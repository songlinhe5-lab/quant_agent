# ==========================================
# 🌊 加州从采集节点 .env 配置模板
# ==========================================
# 部署路径: /opt/quant-agent/.env
# 角色: Slave (轻量采集 API，不运行 Redis/PostgreSQL)
# COMPOSE_PROFILES=slave
# ==========================================
# 前置条件:
#   1. Tailscale 已安装并加入 Tailnet
#   2. 能通过 Tailscale IP ping 通北京主节点 Redis
#   3. Docker + Docker Compose 已安装
# ==========================================

# 节点角色
NODE_ROLE=slave
COMPOSE_PROFILES=slave

# 从节点标识 (唯一，用于 Redis 注册与服务池发现)
SLAVE_ID=california-1
# 从节点对外 IP (Master 通过此地址 HTTP 回调)
# 使用 Tailscale 内网 IP，禁止暴露公网端口
NODE_HOST=100.x.x.x
NODE_PORT=8001

# ==========================================
# 多 Master 注册 (核心配置!)
# ==========================================
# Slave 通过此配置向 Master 的 Redis 心跳注册
# 格式: [{"id":"节点名","host":"Master的Tailscale IP","port":6379,"password":"pwd"}]
# ⚠️ host 必须使用 Tailscale 内网 IP (100.x.x.x)，禁止使用公网 IP
MASTER_NODES=[{"id":"beijing","host":"100.x.x.x","port":6379,"password":"<MASTER_REDIS_PASSWORD>"}]

# ==========================================
# 采集器配置 (加州节点: futu + finnhub + yfinance)
# ==========================================
COLLECTOR_AKSHARE=false
COLLECTOR_FUTU=true
COLLECTOR_FINNHUB=true
COLLECTOR_YFINANCE=true

# ==========================================
# Futu OpenD (加州节点运行)
# ==========================================
FUTU_HOST=127.0.0.1
FUTU_PORT=11111
# FUTU_ENABLED 已弃用, 改用上方的 COLLECTOR_FUTU=true
FUTU_TRD_ENV=SIMULATE
FUTU_PWD_UNLOCK=<FUTU_UNLOCK_PASSWORD>

# ==========================================
# 数据源 API Keys (加州节点需要)
# ==========================================
FINNHUB_API_KEY=<FINNHUB_KEY>
FMP_API_KEY=<FMP_KEY>

# ==========================================
# Redis (从节点不运行本地 Redis)
# ==========================================
# 不设置 REDIS_HOST: slave 通过 MASTER_NODES 连接 master 的 Redis
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# ==========================================
# 安全与加密 (必须与主节点一致!)
# ==========================================
INTERNAL_API_SECRET=<SAME_AS_MASTER>
ENCRYPTION_MASTER_KEY=<SAME_AS_MASTER>

# ==========================================
# 环境
# ==========================================
QUANT_ENV=production
REAL_TRADE_EXECUTE=false

# ==========================================
# 监控通知 (可选，slave 节点可独立告警)
# ==========================================
FEISHU_WEBHOOK_URL=<FEISHU_WEBHOOK>
FEISHU_SECRET=<FEISHU_SECRET>
