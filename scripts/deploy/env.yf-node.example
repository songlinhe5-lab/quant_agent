# ==========================================
# 📊 YFinance 数据子服务节点 .env 配置模板
# ==========================================
# 部署路径: /opt/quant-agent/.env
# 角色: US-YF-A / US-YF-B (YFinance 专用数据节点)
# Compose: docker-compose.yf-node.yml
# ==========================================
# 前置条件:
#   1. Tailscale 已安装并加入 Tailnet (tag:quant-yf)
#   2. 能通过 Tailscale IP ping 通 US-MASTER Redis (100.102.223.44)
#   3. Docker + Docker Compose 已安装
# ==========================================

# ==========================================
# 节点标识 (DIST-11)
# ==========================================
# 节点 ID (必填，唯一标识): us-yf-a 或 us-yf-b
NODE_ID=us-yf-a
# 路由权重 (默认 10，两节点对等)
DS_WEIGHT=10

# ==========================================
# Tailscale 网络 (OPS-02)
# ==========================================
# 本节点 Tailscale IP (端口仅内网可达)
TAILSCALE_IP=100.x.x.x

# ==========================================
# Redis 连接 (主节点，通过 Tailscale)
# ==========================================
# ⚠️ 必须使用 Tailscale 内网 IP，禁止使用公网 IP
REDIS_HOST=100.102.223.44
REDIS_PORT=6379
REDIS_PASSWORD=<MASTER_REDIS_PASSWORD>

# ==========================================
# HMAC 签名 (DIST-07/DIST-10)
# ==========================================
# 必须与主节点 DATA_SOURCE_HMAC_SECRET 一致
DATA_SOURCE_HMAC_SECRET=<SAME_AS_MASTER>

# ==========================================
# 安全与加密
# ==========================================
INTERNAL_API_SECRET=<SAME_AS_MASTER>

# ==========================================
# 环境
# ==========================================
QUANT_ENV=production
OTEL_ENABLED=false

# ==========================================
# 监控通知 (可选)
# ==========================================
FEISHU_WEBHOOK_URL=<FEISHU_WEBHOOK>
FEISHU_SECRET=<FEISHU_SECRET>
