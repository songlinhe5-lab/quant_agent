# ==========================================
# 🏛️ US-MASTER 主节点 .env 配置模板
# ==========================================
# 部署路径: /opt/quant-agent/.env
# 角色: US-MASTER (API/DB/OMS/Futu/Worker)
# Compose: docker-compose.master.yml 或 docker-compose.yml
# ==========================================
# 前置条件:
#   1. Tailscale 已安装并加入 Tailnet (tag:quant-master)
#   2. Futu OpenD 在宿主机运行 (127.0.0.1:11111)
#   3. Docker + Docker Compose 已安装
# ==========================================

# ==========================================
# 节点角色与标识
# ==========================================
NODE_ROLE=master
COMPOSE_PROFILES=master,monitoring

# ==========================================
# Tailscale 网络 (OPS-02)
# ==========================================
# 本节点 Tailscale IP (Redis/Prometheus/Grafana 绑定此 IP)
TAILSCALE_IP=100.102.223.44

# ==========================================
# 数据库 (PostgreSQL)
# ==========================================
DB_USER=quant_admin
DB_PASSWORD=<STRONG_PASSWORD>
DB_NAME=quant_agent_db

# ==========================================
# Redis
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<STRONG_REDIS_PASSWORD>

# ==========================================
# 采集器配置 (DIST-12 灰度切换)
# ==========================================
# 主节点: Futu 本地 + Finnhub/FRED 本地
# YF 流量经 Router 打到 US-YF-A/B (DIST-02)
COLLECTOR_FUTU=true
COLLECTOR_YFINANCE=false          # 💡 DIST-12: 关闭本地 YF，改走 Router
COLLECTOR_FINNHUB=true
COLLECTOR_AKSHARE=false           # AKShare 在 CN 节点

# ==========================================
# YFinance Router (DIST-02/DIST-12)
# ==========================================
# 启用后，YF 请求经 YFinanceRouter 路由到 US-YF-A/B
YF_ROUTER_ENABLED=true
# 子服务 HMAC 签名密钥 (必须与 YF 节点一致)
DATA_SOURCE_HMAC_SECRET=<STRONG_HMAC_SECRET>

# ==========================================
# Futu OpenD (宿主机本地)
# ==========================================
FUTU_HOST=host.docker.internal
FUTU_PORT=11111
FUTU_TRD_ENV=SIMULATE
FUTU_PWD_UNLOCK=<FUTU_UNLOCK_PASSWORD>

# ==========================================
# 数据源 API Keys
# ==========================================
FINNHUB_API_KEY=<FINNHUB_KEY>
FMP_API_KEY=<FMP_KEY>

# ==========================================
# 安全与加密
# ==========================================
INTERNAL_API_SECRET=<STRONG_SECRET>
ENCRYPTION_MASTER_KEY=<STRONG_KEY>

# ==========================================
# 环境
# ==========================================
QUANT_ENV=production
REAL_TRADE_EXECUTE=false

# ==========================================
# 监控通知 (可选)
# ==========================================
FEISHU_WEBHOOK_URL=<FEISHU_WEBHOOK>
FEISHU_SECRET=<FEISHU_SECRET>
