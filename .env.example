# ==========================================
# 🚀 Quant Agent - 环境配置模板
# ==========================================
# 复制此文件为 .env，填写对应配置。
# 严禁将 .env 提交到 Git！

# ==========================================
# 📊 数据采集器 (按需启用)
# ==========================================
COLLECTOR_AKSHARE=false
COLLECTOR_FUTU=true
COLLECTOR_FINNHUB=false
COLLECTOR_YFINANCE=true

# ==========================================
# 🔴 必填项
# ==========================================
# DATABASE_URL: 必须以 sqlite:// 或 postgresql:// 开头
# EMBEDDING_API_KEY: 硅基流动 API Key，不能为空

# ==========================================
# Redis
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ==========================================
# Database
# ==========================================
DB_USER=quant_admin
DB_PASSWORD=quant_pg_secret_2026
DB_NAME=quant_agent_db
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@127.0.0.1:5432/${DB_NAME}
EMBEDDING_DIM=1024

# Meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_API_KEY=your_meilisearch_key_here

# ==========================================
# 🧠 大脑引擎层 (LLM)
# ==========================================
LLM_API_KEY=sk-your_deepseek_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_PRO_MODEL=deepseek-v4-pro
LLM_LIGHTWEIGHT_MODEL=deepseek-v4-flash

# ==========================================
# 🔤 Embedding (硅基流动)
# ==========================================
EMBEDDING_API_KEY=sk-your_siliconflow_api_key_here
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# ==========================================
# 📈 宏观与行情数据源
# ==========================================
FMP_API_KEY=your_financial_modeling_prep_key
FINNHUB_API_KEY=your_finnhub_key_here
AKSHARE_API_KEY=your_akshare_key_here
FRED_API_KEY=your_fred_key_here
EM_SOURCE_PRIORITY=dbnomics,rbi

# ==========================================
# 🏦 交易执行层 (Futu OpenD)
# ==========================================
FUTU_HOST=127.0.0.1
FUTU_PORT=11111
FUTU_TRD_ENV=SIMULATE
FUTU_PWD_UNLOCK=

# ==========================================
# 🔔 通知与告警
# ==========================================
FEISHU_WEBHOOK_URL=your_feishu_webhook_url_here
SERVERCHAN_SENDKEY=your_serverchan_sendkey_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token:abcdefg
TELEGRAM_CHAT_ID=your_chat_id
ALERT_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxxx

# ==========================================
# 🔍 搜索引擎 API (web_search 工具必需)
# ==========================================
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxx
BOCHA_API_KEY=sk-your_bocha_key_here
JINA_API_KEY=jina_your_api_key_here

# ==========================================
# 🔐 OAuth
# ==========================================
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# ==========================================
# 🛡️ 安全与加密
# ==========================================
INTERNAL_API_SECRET=your-super-secret-internal-api-key-change-me
ENCRYPTION_MASTER_KEY=

# ==========================================
# 🌍 全局配置
# ==========================================
QUANT_ENV=development
BACKEND_API_URL=http://127.0.0.1:8000
API_URL_VERSION=v1
REAL_TRADE_EXECUTE=false

# ==========================================
# 📈 OpenTelemetry (可选)
# ==========================================
OTEL_ENABLED=true
OTEL_SERVICE_NAME=quant-agent
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SAMPLING_RATE=1.0

# ==========================================
# 🌐 CORS (可选)
# ==========================================
ALLOWED_ORIGINS=https://your-domain.pages.dev,http://localhost:5173,http://localhost:3000
