# ==========================================
# 🚀 Quant Agent - 环境凭证模板
# ==========================================
# 【注意】复制此文件并重命名为 .env。
# 严禁将真实的 .env 文件提交到 Git 仓库！

# ------------------------------------------
# 1. 大脑引擎层 (LLM API Keys)
# ------------------------------------------
# 推荐配置 GPT-4o 或 Claude 3.5 作为核心推理模型
LLM_API_KEY=sk-your_deepseek_api_key_here
LLM_BASE_URL=   # 默认为空
LLM_MODEL= # 默认为空
LLM_PRO_MODEL=  # 默认为空

OPENAI_API_KEY=sk-your_openai_api_key_here
ANTHROPIC_API_KEY=sk-your_anthropic_api_key_here

EMBEDDING_API_KEY=sk-xxxxxx  # 你的硅基流动 API Key
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# ------------------------------------------
# 2. 宏观与行情数据源 (Data & Macro Layer)
# ------------------------------------------
# 核心宏观经济日历与财报指标 API
FMP_API_KEY=your_financial_modeling_prep_key
FINNHUB_API_KEY=your_free_finnhub_key_here
AKSHARE_API_KEY=your_free_akshare_key_here
FRED_API_KEY=your_Free_fred_key_here

# 备选数据源 (如需交叉验证)
# TIINGO_API_KEY=your_tiingo_api_key_here
# FINVIZ_API_KEY=your_finviz_api_key_here

# ------------------------------------------
# 3. 交易执行层 (Broker & Execution Layer)
# ------------------------------------------
# Futu OpenD 本地网关地址 (VPS内网或 Docker 映射网络)
FUTU_HOST=127.0.0.1
FUTU_PORT=11111
FUTU_TRD_ENV=SIMULATE        # 环境: SIMULATE (模拟盘) 或 REAL (实盘)
FUTU_PWD_UNLOCK= # 实盘解锁密码 (模拟盘留空即可)

# Alpaca API (美股通道 / 回测沙箱)
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key

# ------------------------------------------
# 4. 算力隔离与外包层 (Compute Offload)
# ------------------------------------------
# 用于调用 Modal Serverless 执行重度 Pandas/NumPy 矢量化回测
MODAL_TOKEN_ID=ak-your_modal_token_id
MODAL_TOKEN_SECRET=as-your_modal_token_secret

# ------------------------------------------
# 5. 交互与监控网关 (Gateway & Alerts)
# ------------------------------------------
# 接收 Agent 主动推送的日元套息预警及宏观异动报警
TELEGRAM_BOT_TOKEN=your_telegram_bot_token:abcdefg
# 仅允许白名单用户的 Chat ID 进行交互，防止外部指令注入
TELEGRAM_CHAT_ID=your_chat_id
# 配置微信 (Server酱) 
SERVERCHAN_SENDKEY=your_serverchan_sendkey_here
# 配置飞书 (Feishu)
FEISHU_WEBHOOK_URL=your_feishu_webhook_url_here

GOOGLE_CLIENT_ID="your_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_client_secret"

BING_SEARCH_API_KEY=your_bing_search_api_key_here
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here
GOOGLE_SEARCH_CX=your_google_search_cx_here
TAVILY_API_KEY="tvly-xxxxxxxxxxxxxxxxxxxx"

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ==========================================
# Database Configuration
# ==========================================
DB_USER=quant_admin
DB_PASSWORD=quant_pg_secret_2026
DB_NAME=quant_agent_db

# 告诉系统 BAAI/bge-large-zh-v1.5 模型使用的是 1024 维
EMBEDDING_DIM=1024

# 核心：配置 PostgreSQL 的连接 URL
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@127.0.0.1:5432/${DB_NAME}

# Meilisearch
MEILISEARCH_HOST="http://127.0.0.1:7700"
MEILISEARCH_API_KEY="YOUR_SUPER_SECRET_KEY"

# ------------------------------------------
# 6. 全局风控与环境标识 (Risk & Environment)
# ------------------------------------------
# development (开发) / production (生产 VPS)
QUANT_ENV=development

BACKEND_API_URL=http://127.0.0.1:8000/api

# 🚨 核心风控防线：全局实盘开关
# 默认为 false。除非显式设为 true，否则所有订单指令均进入 Dry-Run 沙箱模式
REAL_TRADE_EXECUTE=false