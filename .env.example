# ==========================================
# 🚀 Quant Agent - 环境凭证模板
# ==========================================
# 复制此文件为 .env，填写对应配置。
# 严禁将 .env 提交到 Git！
#
# 部署方式 (三节点高可用):
#   海外主节点: docker-compose -f docker-compose.master.yml up -d
#   海外备用节点: docker-compose -f docker-compose.yf-backup.yml up -d
#   国内 AKShare 节点: docker-compose -f docker-compose.akshare.yml up -d
#
# 单一 VPS 简化模式 (测试环境):
#   docker compose up -d

# ==========================================
# 📊 数据采集器 (按需启用 true/false)
# ==========================================
# | 采集器     | 说明                          |
# |------------|-------------------------------|
# | akshare    | 港股通/南向资金 (东方财富)    |
# | futu       | 港美股 Level 2 (Futu OpenD)  |
# | finnhub    | 全球内幕交易/新闻             |
# | yfinance   | 宏观指标/大盘 (分布式锁 HA)  |
COLLECTOR_AKSHARE=false
COLLECTOR_FUTU=true
COLLECTOR_FINNHUB=false
COLLECTOR_YFINANCE=true

# ==========================================
# 🔴 必填项 (缺少会启动失败)
# ==========================================
# DATABASE_URL: 必须以 sqlite:// 或 postgresql:// 开头
# EMBEDDING_API_KEY: 硅基流动 API Key，不能为空

# ==========================================
# Redis
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ==========================================
# Database
# ==========================================
DB_USER=quant_admin
DB_PASSWORD=quant_pg_secret_2026
DB_NAME=quant_agent_db
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@127.0.0.1:5432/${DB_NAME}
EMBEDDING_DIM=1024

# Meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_API_KEY=your_meilisearch_key_here

# ==========================================
# 🧠 大脑引擎层 (LLM)
# ==========================================
LLM_API_KEY=sk-your_deepseek_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_PRO_MODEL=deepseek-chat

# ==========================================
# 🔤 Embedding (硅基流动)
# ==========================================
EMBEDDING_API_KEY=sk-your_siliconflow_api_key_here
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# ==========================================
# 📈 宏观与行情数据源
# ==========================================
FMP_API_KEY=your_financial_modeling_prep_key
FINNHUB_API_KEY=your_finnhub_key_here
AKSHARE_API_KEY=your_akshare_key_here
FRED_API_KEY=your_fred_key_here

# ==========================================
# 🏦 交易执行层 (Futu OpenD)
# ==========================================
FUTU_HOST=127.0.0.1
FUTU_PORT=11111
FUTU_TRD_ENV=SIMULATE
# 实盘解锁密码 (REAL_TRADE_EXECUTE=true 时必填)
FUTU_PWD_UNLOCK=

# ==========================================
# 🔔 通知与告警
# ==========================================
# 飞书机器人 (Grafana 报警 + Agent 推送)
FEISHU_WEBHOOK_URL=your_feishu_webhook_url_here
# Server酱 (微信推送)
SERVERCHAN_SENDKEY=your_serverchan_sendkey_here
# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token:abcdefg
TELEGRAM_CHAT_ID=your_chat_id
# 钉钉报警
ALERT_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxxx

# ==========================================
# 🔍 搜索引擎 API
# ==========================================
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here
GOOGLE_SEARCH_CX=your_google_search_cx_here
BING_SEARCH_API_KEY=your_bing_search_api_key_here
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxx
BOCHA_API_KEY=sk-your_bocha_key_here

# ==========================================
# 🔐 OAuth
# ==========================================
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# ==========================================
# 🛡️ 安全与加密
# ==========================================
INTERNAL_API_SECRET=your-super-secret-internal-api-key-change-me
# 64 位 hex 密钥，用于敏感字段加密 (可选)
ENCRYPTION_MASTER_KEY=

# ==========================================
# 🌍 全局风控与环境
# ==========================================
# development (开发) / production (生产 VPS)
QUANT_ENV=development
BACKEND_API_URL=http://127.0.0.1:8000/api
# 🚨 实盘开关：默认 false，所有订单进入 Dry-Run 沙箱
REAL_TRADE_EXECUTE=false

# ==========================================
# 📈 OpenTelemetry (可选)
# ==========================================
OTEL_ENABLED=true
OTEL_SERVICE_NAME=quant-agent
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SAMPLING_RATE=1.0

# ==========================================
# 🌐 CORS (可选)
# ==========================================
ALLOWED_ORIGINS=https://your-domain.pages.dev,http://localhost:5173,http://localhost:3000

# ==========================================
# 🔄 跨节点数据源路由 (三节点高可用)
# ==========================================
# | 配置项                      | 说明                                  |
# |-----------------------------|---------------------------------------|
# | DATA_SOURCE_ROUTER_ENABLED  | 是否启用跨节点数据源路由              |
# | DATA_SOURCE_HMAC_SECRET     | 节点间通信签名密钥（所有节点必须一致） |
# | DATA_SOURCE_ALLOWED_IPS     | IP 白名单（逗号分隔，公网模式必填）   |
# | YF_PRIMARY_NODE_URL         | YFinance 主节点地址                   |
# | YF_BACKUP_NODE_URL          | YFinance 备用节点地址（防限流）       |
# | AKSHARE_REMOTE_URL          | AKShare 远程节点地址（国内 VPS）      |
#
# 三节点部署配置示例:
#
# ──────────────────────────────────────────
# 方案 A: Tailscale 内网模式（推荐）
# ──────────────────────────────────────────
# 📍 海外主节点 .env:
#   DATA_SOURCE_ROUTER_ENABLED=true
#   DATA_SOURCE_HMAC_SECRET=your-hmac-secret-key
#   YF_PRIMARY_NODE_URL=http://localhost:8000
#   YF_BACKUP_NODE_URL=http://yf-backup.ts.net:8000      # Tailscale DNS
#   AKSHARE_REMOTE_URL=http://akshare-cn.ts.net:8000     # Tailscale DNS
#   COLLECTOR_FUTU=true
#   COLLECTOR_YFINANCE=true
#   COLLECTOR_AKSHARE=false
#
# 📍 海外备用节点 .env:
#   DATA_SOURCE_ROUTER_ENABLED=false
#   DATA_SOURCE_HMAC_SECRET=your-hmac-secret-key (必须与主节点一致)
#   COLLECTOR_FUTU=false
#   COLLECTOR_YFINANCE=true
#   COLLECTOR_AKSHARE=false
#
# 📍 国内 AKShare 节点 .env:
#   DATA_SOURCE_ROUTER_ENABLED=false
#   DATA_SOURCE_HMAC_SECRET=your-hmac-secret-key (必须与主节点一致)
#   COLLECTOR_FUTU=false
#   COLLECTOR_YFINANCE=false
#   COLLECTOR_AKSHARE=true
#
# ──────────────────────────────────────────
# 方案 B: 公网 IP + HTTPS 模式（替代 Tailscale）
# ──────────────────────────────────────────
# 注意：公网模式必须启用以下安全机制：
#   1. HTTPS (TLS 1.2+) - 数据加密传输
#   2. DATA_SOURCE_HMAC_SECRET - 请求签名防篡改
#   3. DATA_SOURCE_ALLOWED_IPS - IP 白名单限制访问
#   4. 时间戳防重放攻击（系统内置 ±5分钟窗口）
#
# 📍 海外主节点 .env:
#   DATA_SOURCE_ROUTER_ENABLED=true
#   DATA_SOURCE_HMAC_SECRET=your-hmac-secret-key
#   DATA_SOURCE_ALLOWED_IPS=备用节点公网IP,国内节点公网IP
#   YF_PRIMARY_NODE_URL=http://localhost:8000
#   YF_BACKUP_NODE_URL=https://yf-backup.your-domain.com:8000   # HTTPS + 公网域名
#   AKSHARE_REMOTE_URL=https://akshare.your-domain.cn:8000      # HTTPS + 国内域名
#   COLLECTOR_FUTU=true
#   COLLECTOR_YFINANCE=true
#   COLLECTOR_AKSHARE=false
#
# 📍 海外备用节点 .env:
#   DATA_SOURCE_ROUTER_ENABLED=false
#   DATA_SOURCE_HMAC_SECRET=your-hmac-secret-key (必须与主节点一致)
#   DATA_SOURCE_ALLOWED_IPS=主节点公网IP
#   COLLECTOR_FUTU=false
#   COLLECTOR_YFINANCE=true
#   COLLECTOR_AKSHARE=false
#
# 📍 国内 AKShare 节点 .env:
#   DATA_SOURCE_ROUTER_ENABLED=false
#   DATA_SOURCE_HMAC_SECRET=your-hmac-secret-key (必须与主节点一致)
#   DATA_SOURCE_ALLOWED_IPS=主节点公网IP
#   COLLECTOR_FUTU=false
#   COLLECTOR_YFINANCE=false
#   COLLECTOR_AKSHARE=true
#
# 节点间网络:
#   推荐使用 Tailscale 组网，所有节点加入同一 Tailscale 网络
#   使用 Tailscale DNS (xxx.ts.net) 访问其他节点
#   无需公网暴露 8000 端口，安全且延迟低
# ==========================================
DATA_SOURCE_ROUTER_ENABLED=false
DATA_SOURCE_HMAC_SECRET=your-data-source-hmac-secret-change-me
YF_PRIMARY_NODE_URL=http://localhost:8000
YF_BACKUP_NODE_URL=
AKSHARE_REMOTE_URL=
