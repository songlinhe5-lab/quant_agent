# ==========================================
# 🚀 Quant Agent - 环境凭证模板
# ==========================================
# 复制此文件为 .env，根据节点角色修改对应配置。
# 严禁将 .env 提交到 Git！
#
# 部署方式 (统一 compose 文件，profiles 控制角色):
#   主节点: COMPOSE_PROFILES=master docker compose up -d
#   主节点 + 监控: COMPOSE_PROFILES=master,monitoring docker compose up -d
#   从节点: COMPOSE_PROFILES=slave docker compose up -d

# ==========================================
# 🌐 节点拓扑配置
# ==========================================
# 节点角色: master (主节点) 或 slave (从采集节点)
NODE_ROLE=master

# Docker Compose Profiles (控制启动哪些服务)
# master     = Redis + PostgreSQL + API + Worker + 可配置采集器
# slave      = 轻量采集 API (连接 MASTER_NODES 的 Redis)
# monitoring = Prometheus + Grafana (仅 master 可叠加)
COMPOSE_PROFILES=master

# --- Slave 节点专用 (主节点忽略) ---
# SLAVE_ID=overseas-1
# NODE_HOST=your-slave-public-ip
# NODE_PORT=8001
# 多 Master 注册 (JSON 数组，Slave 向每个 Master 的 Redis 心跳注册)
# MASTER_NODES=[{"id":"beijing","host":"120.53.84.116","port":6379,"password":"xxx"}]

# --- Master 节点专用 (从节点忽略) ---
# 静态从节点列表 (逗号分隔，冷启动兜底，运行时自动发现)
# SLAVE_NODES=http://overseas-1:8001,http://yf-node-1:8001

# ------------------------------------------
# 数据采集器 (每个节点独立配置 true/false)
# ------------------------------------------
# | 采集器     | 说明                          | 典型节点   |
# |------------|-------------------------------|------------|
# | akshare    | 港股通/南向资金 (东方财富)    | 北京主节点 |
# | futu       | 港美股 Level 2 (Futu OpenD)  | 海外从节点 |
# | finnhub    | 全球内幕交易/新闻             | 海外从节点 |
# | yfinance   | 宏观指标/大盘 (分布式锁 HA)  | 任意节点   |
COLLECTOR_AKSHARE=false
COLLECTOR_FUTU=false
COLLECTOR_FINNHUB=false
COLLECTOR_YFINANCE=false
# 📋 典型矩阵:
#   主节点: COLLECTOR_AKSHARE=true,  COLLECTOR_YFINANCE=true
#   海外从: COLLECTOR_FUTU=true,     COLLECTOR_FINNHUB=true

# ==========================================
# 🔴 必填项 (缺少会启动失败)
# ==========================================
# DATABASE_URL: 必须以 sqlite:// 或 postgresql:// 开头
# EMBEDDING_API_KEY: 硅基流动 API Key，不能为空

# ==========================================
# Redis (主节点)
# ==========================================
# 主节点: localhost (compose 内部会覆盖为 redis 服务名)
# 从节点: 不使用此项 (Slave 通过 MASTER_NODES 连接各 master 的 Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ==========================================
# Database (仅主节点)
# ==========================================
DB_USER=quant_admin
DB_PASSWORD=quant_pg_secret_2026
DB_NAME=quant_agent_db
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@127.0.0.1:5432/${DB_NAME}
EMBEDDING_DIM=1024

# Meilisearch (仅主节点)
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_API_KEY=your_meilisearch_key_here

# ==========================================
# 🧠 大脑引擎层 (LLM)
# ==========================================
LLM_API_KEY=sk-your_deepseek_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_PRO_MODEL=deepseek-chat

# ==========================================
# 🔤 Embedding (硅基流动)
# ==========================================
EMBEDDING_API_KEY=sk-your_siliconflow_api_key_here
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# ==========================================
# 📊 宏观与行情数据源
# ==========================================
FMP_API_KEY=your_financial_modeling_prep_key
FINNHUB_API_KEY=your_finnhub_key_here
AKSHARE_API_KEY=your_akshare_key_here
FRED_API_KEY=your_fred_key_here

# ==========================================
# 🏦 交易执行层 (Futu OpenD)
# ==========================================
FUTU_HOST=127.0.0.1
FUTU_PORT=11111
FUTU_TRD_ENV=SIMULATE
# 实盘解锁密码 (REAL_TRADE_EXECUTE=true 时必填)
FUTU_PWD_UNLOCK=

# ==========================================
# 🔔 通知与告警
# ==========================================
# 飞书机器人 (Grafana 报警 + Agent 推送)
FEISHU_WEBHOOK_URL=your_feishu_webhook_url_here
# Server酱 (微信推送)
SERVERCHAN_SENDKEY=your_serverchan_sendkey_here
# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token:abcdefg
TELEGRAM_CHAT_ID=your_chat_id
# 钉钉报警
ALERT_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxxx

# ==========================================
# 🔍 搜索引擎 API
# ==========================================
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here
GOOGLE_SEARCH_CX=your_google_search_cx_here
BING_SEARCH_API_KEY=your_bing_search_api_key_here
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxx
BOCHA_API_KEY=sk-your_bocha_key_here

# ==========================================
# 🔐 OAuth
# ==========================================
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# ==========================================
# 🛡️ 安全与加密
# ==========================================
INTERNAL_API_SECRET=your-super-secret-internal-api-key-change-me
# 64 位 hex 密钥，用于敏感字段加密 (可选)
ENCRYPTION_MASTER_KEY=

# ==========================================
# 🌍 全局风控与环境
# ==========================================
# development (开发) / production (生产 VPS)
QUANT_ENV=development
BACKEND_API_URL=http://127.0.0.1:8000/api
# 🚨 实盘开关：默认 false，所有订单进入 Dry-Run 沙箱
REAL_TRADE_EXECUTE=false

# ==========================================
# 📈 OpenTelemetry (可选)
# ==========================================
OTEL_ENABLED=true
OTEL_SERVICE_NAME=quant-agent
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SAMPLING_RATE=1.0

# ==========================================
# 🌐 CORS (可选)
# ==========================================
ALLOWED_ORIGINS=https://your-domain.pages.dev,http://localhost:5173,http://localhost:3000
