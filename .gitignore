# ============================================
# Quant Agent - Git Ignore 配置
# ============================================

# ============================================
# 1. 操作系统与编辑器缓存
# ============================================
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Windows
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# ============================================
# 2. IDE 与编辑器配置
# ============================================
# Visual Studio Code
.vscode/
*.code-workspace

# IntelliJ IDEA / PyCharm
.idea/
*.iml
*.iws
*.ipr

# Vim
[._]*.s[a-v][a-z]
!*.svg
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]

# Emacs
*~[#]*#

# Sublime Text
*.sublime-workspace
*.sublime-project

# ============================================
# 3. 后端 - Python / FastAPI
# ============================================
# 字节码与缓存
__pycache__/
*.py[cod]
*$py.class
*.so
*.dylib
*.dll

# 虚拟环境
venv/
env/
ENV/
.venv/
env.bak/
venv.bak/

# 打包与分发
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
# 前端 src/lib 目录不忽略（包含 Proto 等库文件）
!frontend/src/lib/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 测试与覆盖率
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
*.cover
*.py,cover
.hypothesis/
.tox/
.nox/

# 类型检查
.mypy_cache/
.dmypy.json
dmypy.json

# Lint 缓存
.ruff_cache/
.flake8_cache/

# Jupyter Notebook
.ipynb_checkpoints/
*.ipynb_checkpoints/

# ============================================
# 4. 前端 - Node.js / Vite / React
# ============================================
# 依赖
node_modules/
.pnp/
.pnp.js/
.yarn/

# 构建产物
dist/
dist-ssr/
build/
coverage/
*.local

# Vite
.vite/
.vite-storybook/

# Next.js
.next/
out/

# Vue
.vuepress/dist/

# Parcel
.parcel-cache/

# Webpack
.webpack/

# TypeScript
*.tsbuildinfo

# ESLint
.eslintcache

# Prettier
.prettierignore

# Storybook
.storybook-out/

# ============================================
# 5. Docker 相关
# ============================================
docker-compose.override.yml
.dockerignore

# ============================================
# 6. 数据库与日志
# ============================================
# 数据库文件
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# Redis
dump.rdb
appendonly.aof

# 日志文件
*.log
*.log.*
logs/
log/

# ============================================
# 7. 环境变量与机密配置
# ============================================
# 环境变量文件
.env
.env.local
.env.development
.env.production
.env.test
.env.staging
.env.slave

# 保留示例文件
!.env.example
!.env.slave.example

# 密钥与证书
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
secrets/
keys/

# AWS
.aws/

# Google Cloud
.gcloud/

# ============================================
# 8. 量化 Agent 专属忽略
# ============================================
# Agent 运行状态与记忆
.hermes/
memory/
session.db
*.session

# 临时报告与导出
reports/*.pdf
reports/*.csv
reports/*.xlsx
!reports/*.md
!reports/*.txt

# Mock 数据
mock_data/
test_data/
fixtures/

# 缓存数据
data/cache/
data/temp/

# ============================================
# 9. 临时文件与备份
# ============================================
# 备份文件
*.bak
*.backup
*.tmp
*.temp
*.swp
*.swo

# 归档文件
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# 文档临时文件
*.docx~
*.xlsx~
*.pptx~

# ============================================
# 10. 其他
# ============================================
# 性能分析
.prof
*.prof

# 调试文件
*.pid
*.pid.lock

# 自定义忽略文件
.customignore
backend/coverage.json

# ============================================
# 11. Flutter 客户端
# ============================================
client/flutter_app/.dart_tool/
client/flutter_app/.flutter-plugins-dependencies
client/flutter_app/.packages
client/flutter_app/build/
client/flutter_app/.idea/
client/flutter_app/**/*.iml
client/flutter_app/ios/Pods/
client/flutter_app/ios/.symlinks/
client/flutter_app/ios/Flutter/Flutter.framework
client/flutter_app/ios/Flutter/Flutter.podspec
client/flutter_app/android/.gradle/
client/flutter_app/android/local.properties
client/flutter_app/android/app/debug
client/flutter_app/android/app/profile
client/flutter_app/android/app/release
