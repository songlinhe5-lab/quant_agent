# ==========================================
# 🏢 Quant Agent - 数据节点环境配置模板
# ==========================================
# 用途: 数据节点 (Slave) 专用 .env，仅运行 AKShare + YFinance 采集器
# 部署: docker compose -f docker-compose.akshare.yml up -d
#
# 使用方法:
#   1. 复制此文件为 .env.slave: cp .env.slave.example .env.slave
#   2. 填写真实的 API Keys 和 Redis 密码
#   3. 确认 REDIS_HOST 指向主节点 Tailscale IP
#
# 关键配置:
#   - REDIS_HOST 指向主节点 Tailscale IP
#   - 不需要 Postgres / Meilisearch / Futu OpenD
# ==========================================

# ==========================================
# 🔴 必填项
# ==========================================
# 💡 数据节点不需要数据库，但 worker.py 导入时会初始化 engine
# 使用 SQLite 占位避免连接报错 (实际不会执行 DB 操作)
DATABASE_URL=sqlite:///./data_node.db

# ==========================================
# 🔴 Redis (指向主节点 Tailscale IP)
# ==========================================
REDIS_HOST=<主节点Tailscale IP，例如 100.102.223.44>
REDIS_PORT=6379
REDIS_PASSWORD=<你的Redis密码>

# ==========================================
# 📊 数据采集器 (数据节点仅 AKShare + YFinance)
# ==========================================
COLLECTOR_AKSHARE=true
COLLECTOR_YFINANCE=true
COLLECTOR_FUTU=false
COLLECTOR_FINNHUB=false

# ==========================================
# 📊 宏观与行情数据源 API Keys
# ==========================================
FINNHUB_API_KEY=<你的Finnhub API Key>
AKSHARE_API_KEY=<你的AKShare API Key>
FRED_API_KEY=<你的FRED API Key>

# ==========================================
# 🧠 Embedding (硅基流动) — worker 启动时可能需要
# ==========================================
EMBEDDING_API_KEY=<你的硅基流动 API Key>
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# ==========================================
# 🔔 通知与告警
# ==========================================
FEISHU_WEBHOOK_URL=<你的飞书Webhook URL>

# ==========================================
# 🔐 安全与加密
# ==========================================
INTERNAL_API_SECRET=<你的Internal API Secret>

# ==========================================
# 🌍 全局
# ==========================================
QUANT_ENV=production
BACKEND_API_URL=http://127.0.0.1:8000/api
